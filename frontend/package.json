    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-router/node": "^7.5.3",
    "@react-router/serve": "^7.5.3",
    "clsx": "^2.1.1",
