    "lucide-react": "^0.460.0",
    "luxon": "^3.7.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.5.3",
    "react-select": "^5.10.2",
    "tailwindcss": "^4.1.4"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.58.1",
    "@react-router/dev": "^7.5.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.4",
