    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "babel-jest": "^30.2.0",
    "dotenv": "^17.2.4",
    "eslint": "^9.37.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.3",
    "prettier": "^3.3.3",
    "react-select-event": "^5.5.1",
    "ts-jest": "^29.4.4",
