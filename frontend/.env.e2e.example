# URL the Playwright tests navigate against (the running app).
E2E_BASE_URL=http://localhost:5173

# URL of the backend API used by the auth setup to obtain a session/token.
E2E_API_URL=http://localhost:3000

# Credentials used by e2e/auth.setup.ts to log in once and save storage state.
E2E_EMAIL=user@example.com
E2E_PASSWORD=change-me
