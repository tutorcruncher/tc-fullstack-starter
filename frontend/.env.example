# Base URL of the backend API the app talks to (the backend dev server runs on :8000).
VITE_API_BASE_URL=http://localhost:8000

# Optional error monitoring (Sentry). Leave unset to disable.
# VITE_SENTRY_DSN=

# Optional distributed tracing (Logfire). Leave unset to disable.
# VITE_LOGFIRE_TRACE_URL=
