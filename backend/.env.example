# Example environment file. Copy to `.env` and adjust for your machine.
#
# Settings are loaded by app/core/config.py (pydantic-settings, case-insensitive).
# Values shown here are safe local-development defaults.
#
# !!! SECRETS MARKED "CHANGE IN PRODUCTION" MUST be overridden before deploying. !!!
# In non-dev, non-test mode the app refuses to start if SECRET_KEY is still the
# insecure default (see InsecureDefaultSecretError in app/core/config.py).
#
# TEMPLATE PLACEHOLDERS: API_KEY_PREFIX (app/auth/keys.py, default 'app_live_') and
# LOGFIRE_SERVICE_NAME below are project-specific — rename them per project.

# Environment: development, staging, production
ENVIRONMENT=development

# Database. The `postgres://` scheme is rewritten to `postgresql://` on load.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter

# Redis (broker + result backend for Celery, and rate-limit counters)
REDIS_URL=redis://localhost:6379/0

# API server
HOST=0.0.0.0
PORT=8000
BASE_URL=http://localhost:8000

# Development / test flags. dev_mode and testing both relax the secret validation.
DEV_MODE=True
TESTING=False

# JWT authentication.
# CHANGE IN PRODUCTION: must be a strong random secret of at least 32 bytes.
SECRET_KEY=local-dev-jwt-secret-not-for-production-use-32b!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# CORS. Comma-separated list of allowed origins. website_url must be included here.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Public website URL (must also appear in ALLOWED_ORIGINS)
WEBSITE_URL=http://localhost:3000

# Frontend URL (used for building links back to the SPA)
FRONTEND_URL=http://localhost:5173

# Sentry error tracking. Leave blank to disable.
# CHANGE IN PRODUCTION: set to your project DSN to enable error reporting.
SENTRY_DSN=

# Logfire observability. Leave LOGFIRE_TOKEN blank to disable instrumentation.
# CHANGE IN PRODUCTION: set LOGFIRE_TOKEN and rename LOGFIRE_SERVICE_NAME per project.
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=development
LOGFIRE_SERVICE_NAME=fastapi-sqlmodel-starter

# Pagination default page size
DFT_PAGE_SIZE=50

# Public API per-organization rate limit (requests per 60s window)
PUBLIC_API_RATE_LIMIT_PER_MINUTE=600

# Run Celery tasks synchronously (eager mode) instead of dispatching to a worker.
# Handy for local development without a running worker.
RUN_JOBS_SYNC=True
