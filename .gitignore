# Root-level ignores for the monorepo. Each subfolder (backend/, frontend/) also
# ships its own .gitignore; git applies both.

# OS / editor
.DS_Store
.idea/
.vscode/
*.sw?

# Env files (never commit real secrets)
.env
.env.local
.env.*.local
.env.e2e

# --- Python / backend ---
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# --- Node / frontend ---
node_modules/
build/
dist/
.react-router/
.vite/
.cache/
*.tsbuildinfo
coverage/
playwright-report/
test-results/
frontend/e2e/.auth/
